# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# The docker-compose.yml included in this repo starts a local instance on 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/litara?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Generate a strong random value for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Server ───────────────────────────────────────────────────────────────────
# HTTP port the API listens on. Default: 3000
# PORT=3000

# ─── Ebook Library ────────────────────────────────────────────────────────────
# Absolute (or cwd-relative) path to the directory containing your ebook files.
# The scanner watches this folder and imports any .epub / .mobi / .azw / .azw3
# / .cbz / .pdf files it finds.
#
# Default when unset: <cwd>/test/ebook-library  (the sample fixture folder)
#
# Docker example — mount a host volume and set this to the container path:
#   volumes:
#     - /mnt/media/books:/books
#   environment:
#     EBOOK_LIBRARY_PATH: /books
# EBOOK_LIBRARY_PATH=./test/ebook-library

# Google Books API key — used when enriching metadata manually.
# Raises the daily rate limit from ~100 to 1 000 requests.
# Obtain one at https://console.cloud.google.com/ (Books API).
# GOOGLE_BOOKS_API_KEY=your-api-key-here

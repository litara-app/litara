{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "roots": ["<rootDir>/test"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testTimeout": 30000,
  "maxWorkers": 1,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@litara/mobi-parser$": "<rootDir>/test/mocks/mobi-parser.js",
    "^@litara/cbz-parser$": "<rootDir>/test/mocks/cbz-parser.js"
  },
  "setupFiles": ["<rootDir>/test/setup/test-env.ts"],
  "globalSetup": "<rootDir>/test/setup/global-setup.ts",
  "globalTeardown": "<rootDir>/test/setup/global-teardown.ts",
  "collectCoverageFrom": [
    "<rootDir>/src/**/*.ts",
    "!<rootDir>/src/main.ts",
    "!<rootDir>/src/**/*.module.ts",
    "!<rootDir>/src/**/*.spec.ts",
    "!<rootDir>/src/**/*.dto.ts",
    "!<rootDir>/src/**/*.interface.ts"
  ]
}
